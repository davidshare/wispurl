# Auth service
AUTH_DATABASE_URL=postgresql+psycopg://postgres:postgres@postgres:5432/auth_db
AUTH_SERVICE_URL=http://auth-service:8000

# Shortener service
SHORTENER_DATABASE_URL=postgresql+psycopg://postgres:postgres@postgres:5432/short_db
SHORTENER_SERVICE_URL=http://shortener-service:8000

# Analytics service
ANALYTICS_DATABASE_URL=postgresql+psycopg://postgres:postgres@postgres:5432/stats_db
ANALYTICS_SERVICE_URL=http://analytics-service:8000
MILESTONES=100,1000,10000

# Internal service-to-service auth (Shortener -> Analytics /events)
INTERNAL_API_KEY=replace-with-a-long-random-internal-key
ANALYTICS_REQUEST_TIMEOUT=2

# Rate limiter service
RATE_LIMITER_URL=http://rate-limiter-service:8000
WINDOW_SECONDS=3600
CREATE_LINK_LIMIT=20
RATE_LIMITER_REQUEST_TIMEOUT=1
RATE_LIMITER_FAIL_OPEN=true

# QR service
QR_SERVICE_URL=http://qr-service:8000
# Base URL encoded into QR images (the public gateway entry point).
PUBLIC_BASE_URL=http://localhost:8080
MIN_SIZE_PX=64
MAX_SIZE_PX=1024
DEFAULT_SIZE_PX=256
CACHE_TTL=86400

# Shared auth
JWT_SECRET=replace-with-a-long-random-secret
JWT_ALGORITHM=HS256
ACCESS_TOKEN_TTL_MINUTES=15
REFRESH_TOKEN_TTL_DAYS=7

# Gateway
CORS_ALLOWED_ORIGINS=http://localhost:3000
REQUEST_CONNECT_TIMEOUT=5
REQUEST_READ_TIMEOUT=30

# Frontend (baked into the client bundle at build time; the URL the BROWSER uses)
NEXT_PUBLIC_API_URL=http://localhost:8080

# Shared infrastructure
REDIS_URL=redis://redis:6379/0
# Non-default creds: RabbitMQ's "guest" user only connects from localhost, so
# services on the Docker network must use a real user. URL must match the creds below.
RABBITMQ_URL=amqp://appuser:apppass@rabbitmq:5672/

# Event flow (Shortener producer, Analytics consumer)
EVENTS_PUBLISH_ENABLED=true
ANALYTICS_HTTP_FALLBACK=false

# Cleanup service
CLEANUP_INTERVAL_SECONDS=60
BATCH_SIZE=500

# Notification service
NOTIFY_CHANNEL=log

# Local backing stores
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=postgres
RABBITMQ_DEFAULT_USER=appuser
RABBITMQ_DEFAULT_PASS=apppass
